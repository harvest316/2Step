nix_direnv_manual_reload
if command -v nix-shell &>/dev/null; then
  use nix
fi

# Route git hooks through mmo-platform delegation hub (DR-223, DR-212).
# Per-repo local config overrides any global core.hooksPath.
if [ -d .git ]; then
  current=$(git config --local --get core.hooksPath 2>/dev/null || true)
  if [ "$current" != "../mmo-platform/hooks" ]; then
    git config --local core.hooksPath ../mmo-platform/hooks
  fi
fi
