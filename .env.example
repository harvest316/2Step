# ─────────────────────────────────────────────────────────────────────────────
# 2Step — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────

DATABASE_PATH=./db/2step.db
PROJECT_NAME=2Step

# ─── Brand / Domain ──────────────────────────────────────────────────────────
BRAND_DOMAIN=auditandfix.com
BRAND_URL=https://auditandfix.com

# ─── Outscraper API (Google Maps data) ────────────────────────────────────────
# Sign up: https://outscraper.com/ (Free tier: 25 requests)
OUTSCRAPER_API_KEY=your_outscraper_api_key_here

# ─── Prospect Filters ────────────────────────────────────────────────────────
# Minimum Google rating to include (default: 4.0)
MIN_GOOGLE_RATING=4.0
# Minimum review count to include (default: 30)
MIN_REVIEW_COUNT=30

# ─── AI Model Versions ───────────────────────────────────────────────────────
# Override to pin a specific version; defaults are in code.
# Run: node ~/code/mmo-platform/scripts/check-model-versions.js
KLING_MODEL=kling-v3
ELEVENLABS_MODEL=eleven_turbo_v2_5

# ─── CF Worker (video-demo-requests stage) ───────────────────────────────────
API_WORKER_URL=https://auditandfix-api.auditandfix.workers.dev
API_WORKER_SECRET=your_worker_secret_here

# ─── E2E Testing ─────────────────────────────────────────────────────────────
# Set to "true" to enable E2E tests that hit live workers
# E2E_ENABLED=true

# ─── Shared secrets ──────────────────────────────────────────────────────────
# Loaded from ../333Method/.env.secrets (temporary, moves to mmo-platform later):
# UNSUBSCRIBE_WORKER_URL, UNSUBSCRIBE_SECRET
